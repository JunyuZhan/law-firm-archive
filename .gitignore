# =====================================================
# 档案管理系统 .gitignore
# =====================================================

# Maven
**/target/
**/.mvn/
**/mvnw
**/mvnw.cmd

# IDE
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
*~
.kiro/
.claude/

# Eclipse
.classpath
.project
.settings/
.factorypath

# OS
.DS_Store
Thumbs.db

# Logs
*.log
**/logs/

# Environment
.env
.env.local
.env.*.local

# Node modules
**/node_modules/
**/.vite/
**/.turbo/

# Build outputs
**/dist/
**/build/
**/out/
**/bin/
**/*.zip

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Database
*.db
*.sqlite
*.sqlite3

# Backup files
**/backups/
__pycache__/
*.pyc
*.jqwik-database

# SSL Certificates
**/*.pem
**/*.key
**/*.crt
**/*.p12
**/*.pfx

# Secrets
**/secrets/*
!**/secrets/README.md
!**/secrets/.gitkeep

# Cursor IDE
.cursor/
!.cursor/rules/
