# =====================================================
# 智慧律所管理系统 - 环境变量配置
# =====================================================
# 复制此文件为 .env 并修改配置值
# cp .env.example .env
# 
# ⚠️ 安全警告：
# - 不要将 .env 文件提交到版本控制
# - 所有密钥应使用强随机值
# - 定期轮换密钥
# =====================================================

# ============== 数据库配置 ==============
# Docker 内部服务名（生产环境使用 postgres）
DB_HOST=postgres
DB_PORT=5432
DB_NAME=law_firm
DB_USERNAME=law_admin
# 数据库密码（必须设置强密码）
# 生成方式: openssl rand -base64 24
DB_PASSWORD=your_secure_db_password_here

# ============== Redis配置 ==============
# Docker 内部服务名（生产环境使用 redis）
REDIS_HOST=redis
REDIS_PORT=6379
# Redis 密码（生产环境必须设置）
# 生成方式: openssl rand -base64 24
REDIS_PASSWORD=your_redis_password_here

# ============== JWT安全配置 ==============
# JWT 密钥（必须设置！至少64字符）
# 生成方式: openssl rand -base64 64
# ⚠️ 修改此密钥会使所有现有登录失效
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_here_at_least_64_characters

# ============== MinIO对象存储配置 ==============
# Docker 内部服务地址（生产环境使用 minio:9000）
MINIO_ENDPOINT=http://minio:9000
# 外部访问地址（用于生成浏览器可访问的 URL）
# 如果配置了此地址，缩略图等资源会使用外部地址
MINIO_EXTERNAL_ENDPOINT=http://minio:9000
# MinIO 访问密钥（必须设置强密码，不能使用默认的 minioadmin）
# 生成方式: openssl rand -base64 24
MINIO_ACCESS_KEY=lawfirm_minio_admin
MINIO_SECRET_KEY=your_secure_minio_password_here
# MinIO 存储桶名称
MINIO_BUCKET=law-firm

# ============== OnlyOffice配置 ==============
# JWT 密钥（生产环境必须设置，与容器配置一致）
# 生成方式: openssl rand -base64 64
ONLYOFFICE_JWT_SECRET=your-onlyoffice-jwt-secret-key-here
# 启用 JWT 验证（生产环境必须为 true）
ONLYOFFICE_JWT_ENABLED=true
# OnlyOffice Document Server 地址（浏览器访问）
# 如果使用 IP，格式：http://your-ip/onlyoffice
# 如果使用域名，格式：http://yourdomain.com/onlyoffice
ONLYOFFICE_URL=http://localhost/onlyoffice
# OnlyOffice 回调 URL（使用 Docker 内部服务名，重要！）
ONLYOFFICE_CALLBACK_URL=http://backend:8080/api
# OnlyOffice 外部访问地址（用于生成文件 URL，OnlyOffice 通过 Nginx 代理访问）
# 格式：http://你的域名或IP（不包含 /api 路径）
# 例如：http://192.168.50.10 或 http://oa.albertzhan.top
# 如果配置了此地址，OnlyOffice 将通过 Nginx 代理访问文件，而不是直接访问 Docker 内部地址
ONLYOFFICE_EXTERNAL_ACCESS_URL=

# ============== OCR服务安全配置 ==============
# OCR 服务地址（Docker 内部服务名）
OCR_SERVICE_URL=http://paddle-ocr:8000
# API Key（生产环境必须设置）
# 生成方式: openssl rand -hex 32
OCR_API_KEY=your_ocr_api_key_here
OCR_API_KEY_ENABLED=true
OCR_RATE_LIMIT_REQUESTS=30
OCR_RATE_LIMIT_WINDOW=60
OCR_MAX_FILE_SIZE=10485760

# ============== 安全配置 ==============
# API文档（生产环境必须关闭）
SWAGGER_ENABLED=false
# Spring 环境配置
SPRING_PROFILES_ACTIVE=prod

# ============== 文档站点配置 ==============
# 文档站点登录用户名
DOCS_USERNAME=admin
# 文档站点登录密码（自动生成）
# 生成方式: openssl rand -base64 16
DOCS_PASSWORD=your_docs_password_here

# ============== 监控配置（可选）==============
# Grafana 监控密码
# 生成方式: openssl rand -base64 16
GRAFANA_PASSWORD=your_grafana_password_here
