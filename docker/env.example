# =====================================================
# 生产环境环境变量配置示例
# =====================================================
# 使用方法：
#   1. 复制此文件为 .env: cp env.example .env
#   2. 修改所有密码和密钥为强密码
#   3. 不要将 .env 文件提交到 Git
# =====================================================

# ============================================
# 数据库配置
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=law_firm
DB_USERNAME=law_admin
# ⚠️ 必须修改：设置强密码（16位以上，包含大小写字母、数字、特殊字符）
DB_PASSWORD=your-strong-db-password-here

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
# ⚠️ 建议设置：生产环境建议设置密码
REDIS_PASSWORD=your-redis-password-here

# ============================================
# JWT 配置
# ============================================
# ⚠️ 必须修改：生成强随机密钥（至少64字符）
# 生成命令: openssl rand -base64 64
JWT_SECRET=your-very-long-and-secure-jwt-secret-key-here-at-least-64-characters

# ============================================
# MinIO 对象存储配置
# ============================================
# 选项1：使用项目内置的 MinIO（默认）
# 选项2：使用共享 MinIO（如果服务器上有共享 MinIO 服务）
# 如果使用共享 MinIO，设置 USE_SHARED_MINIO=true，并配置共享 MinIO 的连接信息

# 是否使用共享 MinIO（true/false）
# 如果为 true，将不会启动项目内置的 MinIO 容器，而是连接到共享 MinIO
USE_SHARED_MINIO=false

# Docker 内部地址（使用内置 MinIO 时）
# 如果使用共享 MinIO，改为共享 MinIO 的容器名称，如：http://shared-minio:9000
MINIO_ENDPOINT=http://minio:9000
MINIO_EXTERNAL_ENDPOINT=http://minio:9000

# ⚠️ 必须配置：浏览器访问端点（用于生成缩略图 URL）
# 格式：http://你的IP:9000（MinIO 端口需要对外暴露）
# 例如：http://192.168.50.10:9000
# 如果使用共享 MinIO，改为共享 MinIO 的外部访问地址
MINIO_BROWSER_ENDPOINT=http://your-ip:9000

# ⚠️ 必须修改：不能使用默认的 minioadmin
# 如果使用共享 MinIO，使用共享 MinIO 的访问密钥
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=law-firm

# 共享 MinIO 配置（仅在 USE_SHARED_MINIO=true 时使用）
# 共享 MinIO 的容器名称（Docker 网络内）
SHARED_MINIO_HOST=shared-minio
SHARED_MINIO_PORT=9000
# 共享 MinIO 的网络名称（如果共享 MinIO 在不同的网络中）
SHARED_MINIO_NETWORK=shared-network

# ============================================
# OnlyOffice 文档服务配置
# ============================================
# ⚠️ 必须修改：设置强密钥
# 生成命令: openssl rand -base64 64
ONLYOFFICE_JWT_SECRET=your-onlyoffice-jwt-secret-key-here
ONLYOFFICE_JWT_ENABLED=true
# OnlyOffice URL（浏览器访问地址）
# 格式：http://你的IP或域名/onlyoffice
# 例如：http://192.168.50.10/onlyoffice
ONLYOFFICE_URL=http://your-ip/onlyoffice
# OnlyOffice 回调 URL（必须使用 Docker 内部地址！）
ONLYOFFICE_CALLBACK_URL=http://backend:8080/api

# ============================================
# OCR 服务配置（可选）
# ============================================
OCR_SERVICE_URL=http://paddle-ocr:8000
OCR_API_KEY=your-ocr-api-key-here

# ============================================
# Grafana 监控配置
# ============================================
# ⚠️ 必须修改：修改默认密码
GRAFANA_PASSWORD=your-grafana-password-here

# ============================================
# 应用配置
# ============================================
SPRING_PROFILES_ACTIVE=prod
SWAGGER_ENABLED=false

# ============================================
# 文档站点配置
# ============================================
# 文档站点登录用户名
DOCS_USERNAME=admin
# 文档站点登录密码（首次部署时由一键部署脚本自动生成）
# 生成方式: openssl rand -base64 16
# 查看密码: cat .env | grep DOCS_PASSWORD
DOCS_PASSWORD=your-docs-password-here

# ============================================
# 其他配置（可选）
# ============================================
# 备份路径
BACKUP_PATH=/var/backups
# 迁移脚本路径
MIGRATION_PATH=/var/scripts/migration
