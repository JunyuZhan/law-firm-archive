# =====================================================
# 环境配置模板
# =====================================================
# 
# 🔐 推荐方式（Docker Secrets，更安全）：
#   cd docker/secrets && ./init-secrets.sh
#   docker compose -f docker/docker-compose.yml up -d
#
# 📝 传统方式（环境变量，docker inspect 可见密钥）：
#   cp env.example .env && vim .env
#   docker compose --env-file .env -f docker/examples/docker-compose.env-vars.yml up -d
#
# =====================================================

# ============================================
# 数据库配置
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=law_firm
DB_USERNAME=law_admin
# ⚠️ 必须修改：设置强密码（16位以上，包含大小写字母、数字、特殊字符）
DB_PASSWORD=your-strong-db-password-here

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
# ⚠️ 建议设置：生产环境建议设置密码
REDIS_PASSWORD=your-redis-password-here

# ============================================
# JWT 配置
# ============================================
# ⚠️ 必须修改：生成强随机密钥（至少64字符）
# 生成命令: openssl rand -base64 64
JWT_SECRET=your-very-long-and-secure-jwt-secret-key-here-at-least-64-characters

# ============================================
# MinIO 对象存储配置
# ============================================
# MinIO 容器使用无前缀名称（minio），可以与其他应用共享
# 如果服务器上已有 minio 容器，将自动使用共享的 MinIO
# Docker 内部地址（使用无前缀的 minio 容器名）
MINIO_ENDPOINT=http://minio:9000
MINIO_EXTERNAL_ENDPOINT=http://minio:9000

# ⚠️ 必须配置：浏览器访问端点（用于生成缩略图 URL）
# 单端口架构：使用相对路径，通过 Nginx 代理访问
# 格式：/minio（相对路径，推荐）
# 或者：http://你的域名/minio（完整 URL，如果使用域名）
# 例如：/minio 或 http://your-domain/minio
MINIO_BROWSER_ENDPOINT=/minio

# MinIO 访问密钥（首次部署时自动生成，项目专用）
# 每个项目运行自己的 MinIO 容器，自动生成不同的密码
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=law-firm

# MinIO 镜像版本（可选，默认使用 GUI 最后完整版）
# GUI 最后完整版：RELEASE.2024-07-15T19-02-30Z
# MINIO_VERSION=RELEASE.2024-07-15T19-02-30Z
# MINIO_MC_VERSION=latest

# ============================================
# OnlyOffice 文档服务配置
# ============================================
# ⚠️ 必须修改：设置强密钥
# 生成命令: openssl rand -base64 64
ONLYOFFICE_JWT_SECRET=your-onlyoffice-jwt-secret-key-here
ONLYOFFICE_JWT_ENABLED=true
# OnlyOffice URL（浏览器访问地址）
# 格式：http://你的IP或域名/onlyoffice
# 例如：http://192.168.50.10/onlyoffice
ONLYOFFICE_URL=http://your-ip/onlyoffice
# OnlyOffice 回调 URL（必须使用 Docker 内部地址！）
ONLYOFFICE_CALLBACK_URL=http://backend:8080/api

# ============================================
# OCR 服务配置（可选）
# ============================================
OCR_SERVICE_URL=http://paddle-ocr:8000
OCR_API_KEY=your-ocr-api-key-here

# ============================================
# Grafana 监控配置
# ============================================
# ⚠️ 建议修改：Grafana 管理员密码
# 生成命令: openssl rand -base64 16
GRAFANA_PASSWORD=your-grafana-password-here

# ============================================
# 应用配置
# ============================================
SPRING_PROFILES_ACTIVE=prod
SWAGGER_ENABLED=false

# ============================================
# 文档站点配置
# ============================================
# 文档站点登录用户名
DOCS_USERNAME=admin
# 文档站点登录密码（首次部署时由一键部署脚本自动生成）
# 生成方式: openssl rand -base64 16
# 查看密码: cat .env | grep DOCS_PASSWORD
DOCS_PASSWORD=your-docs-password-here

# ============================================
# PostgreSQL 主从复制配置（仅主从架构需要）
# ============================================
# 复制用户名
# POSTGRES_REPLICATION_USER=replicator
# ⚠️ 必须修改：复制用户密码
# 生成命令: openssl rand -base64 32
# POSTGRES_REPLICATION_PASSWORD=your-replication-password-here
# 主库地址（从库配置时使用）
# POSTGRES_MASTER_HOST=192.168.50.10
# POSTGRES_MASTER_PORT=5432

# ============================================
# 其他配置（可选）
# ============================================
# 备份路径
BACKUP_PATH=/var/backups
# 迁移脚本路径
MIGRATION_PATH=/var/scripts/migration
