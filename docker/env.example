# =====================================================
# 律师事务所管理系统 - 生产环境配置模板
# =====================================================
# 复制此文件为 .env 并修改配置值
# cp env.example .env
# =====================================================

# ============== 数据库配置 ==============
DB_PASSWORD=your_secure_db_password_here

# ============== Redis配置 ==============
# 留空则不需要密码
REDIS_PASSWORD=

# ============== JWT安全配置 ==============
# 必须设置！生成方式: openssl rand -base64 64
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_here_at_least_64_characters

# ============== MinIO对象存储配置 ==============
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_secure_minio_password_here

# ============== 可选配置 ==============
# API文档（生产环境建议关闭）
SWAGGER_ENABLED=false

# ============== OnlyOffice配置（可选） ==============
# ONLYOFFICE_JWT_SECRET=your_onlyoffice_jwt_secret

# ============== AI服务配置（可选） ==============
# DEEPSEEK_API_KEY=your_deepseek_api_key
# OPENAI_API_KEY=your_openai_api_key

