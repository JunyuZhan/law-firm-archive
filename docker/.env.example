# ============================================================
# 档案管理系统 Docker Compose 环境变量
# ============================================================
# 使用方式：cp .env.example .env  然后修改密码
#
# 部署模式：
#   本地构建：docker compose up -d --build
#   生产拉取：设置 REGISTRY_PREFIX 后 docker compose up -d
# ============================================================

# --- 必填：数据库与中间件密码 ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-db-password
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-minio-password
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=change-this-rabbitmq-password

# --- 必填：安全密钥（至少 32 字节 UTF-8）---
JWT_SECRET=change-this-jwt-secret-to-at-least-32-characters
# 可选；不填则默认与 JWT_SECRET 相同
SECURITY_CRYPTO_SECRET=
# 可选；密钥迁移时填写旧密钥，迁移完成后清空
SECURITY_CRYPTO_LEGACY_SECRET=

# --- 镜像仓库与版本 ---
# 本地构建部署时留空；生产拉取部署时设置为仓库前缀（含末尾 /），例如：
#   REGISTRY_PREFIX=hub.albertzhan.top/
REGISTRY_PREFIX=
# 镜像拉取策略：missing（仅本地缺失时拉取）、always（每次都拉取）
PULL_POLICY=missing
# 应用版本标签（与 VERSION 文件一致；生产拉取时指定具体版本）
APP_VERSION=
# Elasticsearch 堆内存（MB）
ES_HEAP_MB=192

# --- 构建元信息（可选，由 CI 脚本自动注入）---
APP_COMMIT_SHA=
APP_BUILD_TIME=
RUNNING_BACKEND_DIGEST=
RUNNING_FRONTEND_DIGEST=
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# --- 网络与代理 ---
# 外部访问来源域名（逗号分隔，追加到 CORS 白名单）
EXTERNAL_ORIGIN=
# MinIO 预签名 URL 的 Nginx 代理前缀
MINIO_PROXY_PREFIX=/storage
# 前端服务对外端口
FRONTEND_PORT=3001
# CORS 允许的来源（默认即可，EXTERNAL_ORIGIN 会追加到末尾）
CORS_ALLOWED_ORIGINS=http://localhost:3001

# --- 分发中心（可选）---
# 填写后，后台可在「系统信息」中与分发中心比对版本
# DIST_CENTER_LATEST_JSON_URL=https://你的分发域名/projects/law-firm-archive/versions/latest.json
