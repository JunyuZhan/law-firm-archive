# ============================================================================
# 档案管理系统 - 部署环境变量模板
# ============================================================================
# 复制本文件为 .env 并修改对应值
# cp .env.example .env
# ============================================================================

# 外网访问域名（CORS 允许的外部来源）
EXTERNAL_ORIGIN=https://your-domain.example.com

# MinIO 代理路径前缀（Nginx 中配置的代理路径）
MINIO_PROXY_PREFIX=/storage
