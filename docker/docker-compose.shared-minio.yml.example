# =====================================================
# 共享 MinIO 配置示例
# =====================================================
# 如果多个应用需要共享同一个 MinIO 实例，可以使用此配置
# 通过不同的 bucket 和访问密钥实现数据隔离
# =====================================================
# 使用方法：
# 1. 将此文件复制为 docker-compose.shared-minio.yml
# 2. 配置共享 MinIO 的连接信息
# 3. 在 docker-compose.prod.yml 中移除 minio 服务，添加外部 MinIO 配置
# =====================================================

version: '3.8'

services:
  # ============================================
  # 共享 MinIO 服务（由其他应用或独立部署）
  # ============================================
  # 如果使用外部 MinIO，可以注释掉此服务
  # 并在环境变量中配置外部 MinIO 地址
  shared-minio:
    image: minio/minio:RELEASE.2024-07-15T19-02-30Z
    container_name: shared-minio
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: ${SHARED_MINIO_ROOT_USER:-minioadmin}
      MINIO_ROOT_PASSWORD: ${SHARED_MINIO_ROOT_PASSWORD:-minioadmin}
    volumes:
      - shared_minio_data:/data
    ports:
      - "9000:9000"  # API 端口
      - "9001:9001"  # 控制台
    networks:
      - shared-network
    restart: unless-stopped
    # 资源限制（共享场景下可以设置更合理的限制）
    deploy:
      resources:
        limits:
          cpus: '1'
          memory: 512M
        reservations:
          cpus: '0.25'
          memory: 256M

  # ============================================
  # MinIO 初始化（为不同应用创建独立的 bucket）
  # ============================================
  minio-init:
    image: minio/mc:latest
    container_name: shared-minio-init
    depends_on:
      - shared-minio
    entrypoint: >
      /bin/sh -c "
      sleep 10;
      mc alias set myminio http://shared-minio:9000 $${SHARED_MINIO_ROOT_USER:-minioadmin} $${SHARED_MINIO_ROOT_PASSWORD:-minioadmin};
      # 为 law-firm 应用创建 bucket
      mc mb --ignore-existing myminio/law-firm;
      mc anonymous set download myminio/law-firm/public;
      # 为 pis 应用创建 bucket（如果存在）
      mc mb --ignore-existing myminio/pis;
      mc anonymous set download myminio/pis/public;
      # 为其他应用创建 bucket...
      echo 'Shared MinIO buckets created successfully';
      exit 0;
      "
    environment:
      SHARED_MINIO_ROOT_USER: ${SHARED_MINIO_ROOT_USER:-minioadmin}
      SHARED_MINIO_ROOT_PASSWORD: ${SHARED_MINIO_ROOT_PASSWORD:-minioadmin}
    networks:
      - shared-network

volumes:
  shared_minio_data:
    driver: local

networks:
  shared-network:
    driver: bridge
    name: shared-network
