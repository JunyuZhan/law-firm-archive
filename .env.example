# 智慧律所管理系统 - 环境变量配置
# 复制此文件为 .env 并修改配置值
# cp .env.example .env

# ============================================
# 数据库配置
# ============================================
DB_PASSWORD=your-strong-database-password

# ============================================
# Redis 配置（可选，留空则不设密码）
# ============================================
REDIS_PASSWORD=

# ============================================
# JWT 密钥（必须修改！使用强随机字符串）
# 生成方法：openssl rand -base64 32
# ============================================
JWT_SECRET=please-change-this-to-a-random-256-bit-string

# ============================================
# MinIO 文件存储配置
# ============================================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-strong-minio-password
