# 生产环境配置

# 律所名称（必需，用于浏览器标签页、登录页等）
VITE_APP_TITLE=智慧律所管理系统

# 应用命名空间
VITE_APP_NAMESPACE=智慧律所管理系统

VITE_BASE=/

# 接口地址 - 生产环境API
VITE_GLOB_API_URL=/api

# 是否开启压缩
VITE_COMPRESS=gzip

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
